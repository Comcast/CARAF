{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Comcast/CARAF/Tools/PQBench/pqbench_handoff.schema.json",
  "title": "PQBench → PQLab Handoff",
  "description": "Contract for the artifact PQBench emits per evaluation run: for each asset, the deployment's selected use-case subcategories and the union of applicable performance metrics. PQLab consumes this to decide WHAT to measure. PROPOSED / draft for design review — see x-design-review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "assets"
  ],
  "x-design-review": {
    "state": "PROPOSED — pending PQLab confirmation",
    "confirmed_fields": [
      "name",
      "platform",
      "selected_subcategories"
    ],
    "proposed_fields": {
      "metric_id": "Machine names are placeholders chosen by PQBench; align to PQLab's canonical vocabulary.",
      "units": "Proposed. Open question: does the handoff carry units, or does PQLab own units per metric_id?",
      "algorithm_scope": "Derived hint (KEM/signature family inferred from selected metrics). NOT an algorithm recommendation and NOT a repo requirement; included for discussion, may be dropped."
    },
    "open_questions": [
      "Does the PQLab Orchestrator ingest a JSON config today, and is this its shape? If not, what is the canonical input schema?",
      "What are PQLab's canonical metric_id and unit names? (We align ours to those.)",
      "Should units live in the handoff, or be owned by PQLab per metric_id?",
      "Is algorithm_scope wanted, or out of scope for the handoff?",
      "Should a run carry a stable run_id / asset_id and a target algorithm list, or is that PQLab's concern?"
    ]
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version of this handoff document.",
      "examples": [
        "0.1-draft"
      ]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle state of the contract itself.",
      "enum": [
        "PROPOSED - pending PQLab confirmation",
        "CONFIRMED"
      ]
    },
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp the document was produced."
    },
    "notes": {
      "type": "string",
      "description": "Free-text notes for human readers."
    },
    "assets": {
      "type": "array",
      "description": "One entry per answered asset. Unanswered assets are omitted.",
      "items": {
        "$ref": "#/$defs/asset"
      }
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "platform",
        "selected_subcategories",
        "applicable_metrics"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable asset / deployment name."
        },
        "platform": {
          "type": "string",
          "enum": [
            "Ubuntu",
            "RHEL",
            "Windows"
          ],
          "description": "Target OS. PQLab v1.0 supports Ubuntu and RHEL; Windows is forward-looking and not yet supported."
        },
        "selected_subcategories": {
          "type": "array",
          "minItems": 1,
          "description": "Use-case subcategories tagged for this asset (Step 1).",
          "items": {
            "$ref": "#/$defs/subcategory"
          }
        },
        "applicable_metrics": {
          "type": "array",
          "minItems": 1,
          "description": "Union of metrics applicable to the selected subcategories (Step 2).",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "algorithm_scope": {
          "$ref": "#/$defs/algorithm_scope"
        }
      }
    },
    "subcategory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "subcategory"
      ],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "Energy Constraints",
            "Network Performance",
            "Computational Resources",
            "Security Requirements",
            "Cryptographic Implementation Method"
          ]
        },
        "subcategory": {
          "type": "string",
          "enum": [
            "Very High Energy Constraints",
            "High Energy Constraints",
            "Moderate Energy Constraints",
            "Low Energy Constraints",
            "Minimal Energy Constraints",
            "Low Latency Use Cases",
            "Moderate Latency Use Cases",
            "High Latency Use Cases",
            "High Throughput Use Cases",
            "Moderate Throughput Use Cases",
            "Low Throughput Use Cases",
            "High Computational Power",
            "Moderate Computational Power",
            "Low Computational Power",
            "High Security Use Cases",
            "Moderate Security Use Cases",
            "Minimum Security Use Cases",
            "Hardware-Based Cryptographic Use Cases",
            "Software-Based Cryptographic Use Cases"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "category": {
                "const": "Energy Constraints"
              }
            }
          },
          "then": {
            "properties": {
              "subcategory": {
                "enum": [
                  "Very High Energy Constraints",
                  "High Energy Constraints",
                  "Moderate Energy Constraints",
                  "Low Energy Constraints",
                  "Minimal Energy Constraints"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "category": {
                "const": "Network Performance"
              }
            }
          },
          "then": {
            "properties": {
              "subcategory": {
                "enum": [
                  "Low Latency Use Cases",
                  "Moderate Latency Use Cases",
                  "High Latency Use Cases",
                  "High Throughput Use Cases",
                  "Moderate Throughput Use Cases",
                  "Low Throughput Use Cases"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "category": {
                "const": "Computational Resources"
              }
            }
          },
          "then": {
            "properties": {
              "subcategory": {
                "enum": [
                  "High Computational Power",
                  "Moderate Computational Power",
                  "Low Computational Power"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "category": {
                "const": "Security Requirements"
              }
            }
          },
          "then": {
            "properties": {
              "subcategory": {
                "enum": [
                  "High Security Use Cases",
                  "Moderate Security Use Cases",
                  "Minimum Security Use Cases"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "category": {
                "const": "Cryptographic Implementation Method"
              }
            }
          },
          "then": {
            "properties": {
              "subcategory": {
                "enum": [
                  "Hardware-Based Cryptographic Use Cases",
                  "Software-Based Cryptographic Use Cases"
                ]
              }
            }
          }
        }
      ],
      "description": "A (category, subcategory) pair. subcategory must belong to its category."
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "metric_id",
        "units"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "Throughput",
            "Latency",
            "Packet Loss",
            "Jitter",
            "Interoperability",
            "Scalability",
            "Overall Performance",
            "Key Generation Time",
            "Signature Generation Time",
            "Verification Time",
            "Shared Key Derivation Time",
            "Encryption Time",
            "Decryption Time",
            "Key Size",
            "Signature Size",
            "Memory Consumption",
            "Energy Efficiency",
            "Certificate Throughput",
            "TLS Throughput"
          ],
          "description": "Canonical metric name from the PQBench mapping."
        },
        "metric_id": {
          "type": "string",
          "enum": [
            "throughput_mbps",
            "latency_ms",
            "packet_loss_pct",
            "jitter_ms",
            "interop_result",
            "scalability_max_conns",
            "overall_perf_score",
            "keygen_time_ms",
            "sign_time_ms",
            "verify_time_ms",
            "kem_derive_time_ms",
            "encrypt_time_ms",
            "decrypt_time_ms",
            "key_size_bytes",
            "signature_size_bytes",
            "mem_peak_kb",
            "energy_per_op_mj",
            "cert_throughput_cps",
            "tls_handshakes_per_sec"
          ],
          "description": "PROPOSED machine name — confirm against PQLab vocabulary."
        },
        "units": {
          "type": "string",
          "enum": [
            "Mbps",
            "ms",
            "%",
            "pass/fail",
            "connections",
            "composite",
            "bytes",
            "KB",
            "mJ/op",
            "certs/sec",
            "handshakes/sec"
          ],
          "description": "PROPOSED unit — see open question on ownership."
        }
      }
    },
    "algorithm_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kem",
        "signature"
      ],
      "description": "Derived hint only: which PQC algorithm families the metric set implies. Not a recommendation.",
      "properties": {
        "kem": {
          "type": "boolean",
          "description": "True if KEM-family metrics (e.g. shared-key derivation, TLS throughput) were selected."
        },
        "signature": {
          "type": "boolean",
          "description": "True if signature-family metrics (e.g. signature gen/verify/size, certificate throughput) were selected."
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": "0.1-draft",
      "status": "PROPOSED - pending PQLab confirmation",
      "generated": "2026-06-08T10:00:00",
      "notes": "metric_id and units are proposed; confirm canonical vocabulary and input contract with the PQLab team.",
      "assets": [
        {
          "name": "Streaming Gateway",
          "platform": "Ubuntu",
          "selected_subcategories": [
            {
              "category": "Network Performance",
              "subcategory": "High Throughput Use Cases"
            }
          ],
          "applicable_metrics": [
            {
              "name": "Throughput",
              "metric_id": "throughput_mbps",
              "units": "Mbps"
            },
            {
              "name": "Packet Loss",
              "metric_id": "packet_loss_pct",
              "units": "%"
            },
            {
              "name": "Jitter",
              "metric_id": "jitter_ms",
              "units": "ms"
            },
            {
              "name": "Interoperability",
              "metric_id": "interop_result",
              "units": "pass/fail"
            },
            {
              "name": "Scalability",
              "metric_id": "scalability_max_conns",
              "units": "connections"
            }
          ],
          "algorithm_scope": {
            "kem": false,
            "signature": false
          }
        },
        {
          "name": "Solar Sensor",
          "platform": "RHEL",
          "selected_subcategories": [
            {
              "category": "Energy Constraints",
              "subcategory": "Very High Energy Constraints"
            }
          ],
          "applicable_metrics": [
            {
              "name": "Energy Efficiency",
              "metric_id": "energy_per_op_mj",
              "units": "mJ/op"
            }
          ],
          "algorithm_scope": {
            "kem": false,
            "signature": false
          }
        }
      ]
    }
  ]
}